# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE CONFIGURATION FOR DEPLOYMENT (MariaDB/MySQL)
USE_MARIADB="true"
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD="zara_password"
DB_NAME="zara_db"

# SERVER ENVIRONMENT
NODE_ENV="production"
PORT="3000"

# PERSISTENCE CONFIGURATION (Definitive solution against losing data on updates/rebuilds)
# To prevent losing your sales, users, and uploaded logos/images when you update or rebuild,
# configure these paths to store files COMPLETELY OUTSIDE the app's code repository folder.
# This ensures that git pull, rebuilds, and PM2 restarts never touch your database or uploaded assets!
# Example on Debian:
# SQLITE_DB_PATH="/var/www/zara-data/zara_database.sqlite"
# UPLOADS_DIR="/var/www/zara-data/uploads"
SQLITE_DB_PATH=""
UPLOADS_DIR=""

# Note for Debian Deployment:
# While the internal node server binds to port 3000 (PORT=3000), 
# the docker-compose.yml file exposes it on port 6000, 
# since 3000 is occupied on the target Debian server.
